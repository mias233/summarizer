# AI-Powered YouTube Summarizer - Environment Variables Example
# (DO NOT commit your real .env.local file to GitHub!)

# --- Gemini AI ---
# Get your API key from Google AI Studio
GEMINI_API_KEY=PLACEHOLDER_GEMINI_KEY

# --- Google Authentication ---
# Get these from Google Cloud Console
GOOGLE_CLIENT_ID=PLACEHOLDER_GOOGLE_ID
GOOGLE_CLIENT_SECRET=PLACEHOLDER_GOOGLE_SECRET

# NextAuth configuration
NEXTAUTH_SECRET=PLACEHOLDER_NEXTAUTH_SECRET
NEXTAUTH_URL=http://localhost:3000

# --- Supabase Database ---
# Get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=PLACEHOLDER_SUPABASE_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=PLACEHOLDER_SUPABASE_ANON_KEY
